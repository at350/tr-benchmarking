{
  "run_id": "live_multi_provider_calibration",
  "domain": "auto",
  "source_case_path": "cases/MarriageSoF_Anglemire v Policemens Benev Assn of Chicago.pdf",
  "output_dir": "research/runs/live_multi_provider_calibration",
  "mode": "live_multi_provider",
  "response_prompt_style": "natural",
  "agents": {
    "frank": {
      "mode": "llm",
      "provider": "openai",
      "model": "gpt-5.2",
      "temperature": 0
    },
    "karthic": {
      "mode": "llm",
      "provider": "openai",
      "model": "gpt-5.2",
      "temperature": 0
    },
    "dasha": {
      "mode": "llm",
      "provider": "openai",
      "model": "gpt-5.2",
      "temperature": 0
    }
  },
  "answer_headings": [
    "Jurisdiction assumption",
    "Bottom-line outcome",
    "Controlling doctrine",
    "Transaction / formation characterization",
    "Writing requirement and trigger",
    "Compliance / substitute / exception analysis",
    "Other defenses or competing doctrines",
    "Strongest counterargument"
  ],
  "response_models": [
    {
      "provider": "openai",
      "model": "gpt-5.2",
      "samples": 2,
      "temperature": 0.25
    },
    {
      "provider": "openai",
      "model": "gpt-5.4",
      "samples": 2,
      "temperature": 0.35
    },
    {
      "provider": "anthropic",
      "model": "claude-sonnet-4-20250514",
      "samples": 2,
      "temperature": 0.25
    },
    {
      "provider": "gemini",
      "model": "gemini-3-pro-preview",
      "samples": 2,
      "temperature": 0.25
    },
    {
      "provider": "replicate",
      "model": "meta/meta-llama-3-70b-instruct",
      "samples": 2,
      "temperature": 0.25
    }
  ],
  "clustering": {
    "method": "llm_reasoning_signature",
    "min_cluster_size": 1,
    "min_observed_clusters": 2,
    "mixed_cluster_threshold": 0.34,
    "provider": "openai",
    "model": "gpt-5.2"
  },
  "judge": {
    "mode": "llm",
    "provider": "openai",
    "model": "gpt-5.2",
    "agreement_threshold": 0.7,
    "escalation_margin": 0.2,
    "repeats": 2,
    "judge_models": [
      {
        "provider": "openai",
        "model": "gpt-5.2",
        "repeats": 2,
        "temperature": 0.15
      },
      {
        "provider": "anthropic",
        "model": "claude-sonnet-4-20250514",
        "repeats": 1,
        "temperature": 0.15
      }
    ],
    "temperature": 0.15
  },
  "perturbations": {
    "enabled": true,
    "max_variations": 2,
    "require_invariant": true,
    "require_material": true
  },
  "budget": {
    "max_response_calls": 30,
    "max_judge_calls": 12,
    "max_total_llm_calls_excluding_frank_karthic": 80
  },
  "quality_gates": {
    "min_rubric_rows": 8,
    "max_duplicate_similarity": 0.82,
    "required_categories": [
      "doctrine",
      "rule",
      "facts",
      "exceptions",
      "counterargument"
    ]
  }
}
